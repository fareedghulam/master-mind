rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if ID is valid
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() < 100;
    }

    // Helper to validate User
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'phone', 'city', 'balance'])
        && data.email is string
        && data.name is string && data.name.size() < 150
        && data.phone is string && data.phone.size() < 30
        && data.city is string && data.city.size() < 100
        && data.balance is number
        && (!data.keys().hasAny(['isAdmin']) || data.isAdmin is bool)
        && (!data.keys().hasAny(['role']) || (data.role is string && data.role.size() < 50))
        && (!data.keys().hasAny(['active']) || data.active is bool)
        && (!data.keys().hasAny(['password']) || (data.password is string && data.password.size() < 100));
    }

    // Helper to validate Booking
    function isValidBooking(data) {
      return data.keys().hasAll(['id', 'userEmail', 'category', 'number', 'firstAmount', 'secondAmount', 'timestamp'])
        && data.id is string
        && data.userEmail is string
        && (data.category == 'pakistan_bond' || data.category == 'thailand_lottery')
        && data.number is string
        && data.firstAmount is number
        && data.secondAmount is number
        && data.timestamp is string;
    }

    // Helper to validate NumberLimit
    function isValidLimit(data) {
      return data.keys().hasAll(['id', 'category', 'number', 'maxAmount'])
        && data.id is string
        && (data.category == 'pakistan_bond' || data.category == 'thailand_lottery')
        && data.number is string
        && data.maxAmount is number;
    }

    // Helper to validate Demand
    function isValidDemand(data) {
      return data.keys().hasAll(['id', 'userEmail', 'category', 'number', 'firstAmount', 'secondAmount', 'timestamp', 'status'])
        && data.id is string
        && data.userEmail is string
        && (data.category == 'pakistan_bond' || data.category == 'thailand_lottery')
        && data.number is string
        && data.firstAmount is number
        && data.secondAmount is number
        && data.timestamp is string
        && (data.status == 'pending' || data.status == 'approved' || data.status == 'rejected');
    }

    // Helper to validate DrawDeadline
    function isValidDeadline(data) {
      return data.keys().hasAll(['category', 'titleUrdu', 'deadlineIso', 'status'])
        && (data.category == 'pakistan_bond' || data.category == 'thailand_lottery')
        && data.titleUrdu is string
        && data.deadlineIso is string
        && (data.status == 'open' || data.status == 'closed');
    }

    // Helper to validate Settings
    function isValidSettings(data) {
      return data.keys().hasAll(['adminEmail', 'whatsappNumber'])
        && data.adminEmail is string
        && data.whatsappNumber is string;
    }

    // Helper functions to identify roles
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'mastermaindqureshi110@gmail.com' ||
        request.auth.token.email.lower() == 'mastermaind.qureshi110@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superAdmin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        ))
      );
    }

    function isDataEntryAdmin() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'fareed.ghulam@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dataEntryAdmin'
        ))
      );
    }

    match /users/{uid} {
      allow read: if isSuperAdmin() || isDataEntryAdmin() || (request.auth != null && request.auth.uid == uid);
      allow create: if isValidId(uid) && isValidUser(request.resource.data);
      allow update: if isValidId(uid) && (
        isSuperAdmin() || (
          request.auth != null && 
          request.auth.uid == uid &&
          request.resource.data.balance == resource.data.balance &&
          request.resource.data.isAdmin == resource.data.isAdmin &&
          request.resource.data.role == resource.data.role
        )
      );
      allow delete: if isSuperAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isValidId(bookingId) && isValidBooking(request.resource.data) && (
        isSuperAdmin() || (
          request.auth != null && 
          request.resource.data.userEmail.lower() == request.auth.token.email.lower()
        )
      );
      allow update, delete: if isValidId(bookingId) && (
        isSuperAdmin() || (
          request.auth != null && 
          resource.data.userEmail.lower() == request.auth.token.email.lower()
        )
      );
    }

    match /limits/{limitId} {
      allow read: if true;
      allow write: if isValidId(limitId) && isValidLimit(request.resource.data) && isSuperAdmin();
    }

    match /demands/{demandId} {
      allow read: if true;
      allow create: if isValidId(demandId) && isValidDemand(request.resource.data) && (
        isSuperAdmin() || (
          request.auth != null && 
          request.resource.data.userEmail.lower() == request.auth.token.email.lower()
        )
      );
      allow update: if isValidId(demandId) && isValidDemand(request.resource.data) && (
        isSuperAdmin() || (
          request.auth != null && 
          resource.data.userEmail.lower() == request.auth.token.email.lower() &&
          request.resource.data.status == resource.data.status
        )
      );
      allow delete: if isValidId(demandId) && isSuperAdmin();
    }

    match /deadlines/{category} {
      allow read: if true;
      allow write: if isValidId(category) && isValidDeadline(request.resource.data) && isSuperAdmin();
    }

    match /settings/{configId} {
      allow read: if true;
      allow write: if isValidId(configId) && isValidSettings(request.resource.data) && isSuperAdmin();
    }

    match /pakistanBondResults/{resultId} {
      allow read: if true;
      allow write: if isValidId(resultId) && (isSuperAdmin() || isDataEntryAdmin());
    }

    match /thaiLotteryResults/{resultId} {
      allow read: if true;
      allow write: if isValidId(resultId) && (isSuperAdmin() || isDataEntryAdmin());
    }
  }
}
